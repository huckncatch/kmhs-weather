# Ambient Weather API
# Get your API keys from https://ambientweather.net/account
AMBIENT_WEATHER_API_KEY=
AMBIENT_WEATHER_APP_KEY=

# PWS Weather
# Station ID and API key (if required) from pwsweather.com
PWS_WEATHER_STATION_ID=
PWS_WEATHER_API_KEY=

# Weather Underground
# Personal Weather Station ID from wunderground.com
WUNDERGROUND_PWS_ID=
WUNDERGROUND_API_KEY=

# CoCoRaHS web scraper credentials
COCORAHS_USERNAME=
COCORAHS_PASSWORD=
COCORAHS_SCRAPER_TIMEOUT_MS=30000
